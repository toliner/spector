#!/bin/bash

# Only run in remote environment
if [ "$CLAUDE_CODE_REMOTE" != "true" ]; then
  exit 0
fi

# Check if https_proxy is set
if [ -z "$https_proxy" ]; then
  echo "https_proxy is not set, skipping proxy configuration"
  exit 0
fi

# Parse proxy URL to extract host and port
# Format: http://username:password@host:port or http://host:port
PROXY_URL="$https_proxy"

# Remove protocol (http:// or https://)
PROXY_NO_PROTOCOL="${PROXY_URL#http://}"
PROXY_NO_PROTOCOL="${PROXY_NO_PROTOCOL#https://}"

# Extract authentication and host:port
if [[ "$PROXY_NO_PROTOCOL" == *"@"* ]]; then
  # Has authentication: user:pass@host:port
  AUTH="${PROXY_NO_PROTOCOL%%@*}"
  HOST_PORT="${PROXY_NO_PROTOCOL##*@}"

  # Extract username and password
  PROXY_USER="${AUTH%%:*}"
  PROXY_PASSWORD="${AUTH#*:}"
else
  # No authentication: host:port
  HOST_PORT="$PROXY_NO_PROTOCOL"
  PROXY_USER=""
  PROXY_PASSWORD=""
fi

# Split host and port
PROXY_HOST="${HOST_PORT%:*}"
PROXY_PORT="${HOST_PORT##*:}"

echo "Configuring Java/Gradle proxy settings:"
echo "  Proxy Host: $PROXY_HOST"
echo "  Proxy Port: $PROXY_PORT"
if [ -n "$PROXY_USER" ]; then
  echo "  Proxy User: $PROXY_USER"
  echo "  Proxy Password: [REDACTED]"
fi

# Set Java proxy system properties for Gradle
export JAVA_OPTS="${JAVA_OPTS} -Dhttp.proxyHost=${PROXY_HOST} -Dhttp.proxyPort=${PROXY_PORT} -Dhttps.proxyHost=${PROXY_HOST} -Dhttps.proxyPort=${PROXY_PORT}"
export GRADLE_OPTS="${GRADLE_OPTS} -Dhttp.proxyHost=${PROXY_HOST} -Dhttp.proxyPort=${PROXY_PORT} -Dhttps.proxyHost=${PROXY_HOST} -Dhttps.proxyPort=${PROXY_PORT}"

# Add authentication if present
if [ -n "$PROXY_USER" ]; then
  export JAVA_OPTS="${JAVA_OPTS} -Dhttp.proxyUser=${PROXY_USER} -Dhttp.proxyPassword=${PROXY_PASSWORD} -Dhttps.proxyUser=${PROXY_USER} -Dhttps.proxyPassword=${PROXY_PASSWORD}"
  export GRADLE_OPTS="${GRADLE_OPTS} -Dhttp.proxyUser=${PROXY_USER} -Dhttp.proxyPassword=${PROXY_PASSWORD} -Dhttps.proxyUser=${PROXY_USER} -Dhttps.proxyPassword=${PROXY_PASSWORD}"
fi

# Also set non-proxy hosts if needed (typically localhost and internal networks)
export JAVA_OPTS="${JAVA_OPTS} -Dhttp.nonProxyHosts=localhost|127.0.0.1|*.local"
export GRADLE_OPTS="${GRADLE_OPTS} -Dhttp.nonProxyHosts=localhost|127.0.0.1|*.local"

# Configure SSL to use system certificates
# This is needed when using a TLS-inspecting proxy
export JAVA_OPTS="${JAVA_OPTS} -Djavax.net.ssl.trustStore=/etc/ssl/certs/java/cacerts -Djavax.net.ssl.trustStoreType=jks"
export GRADLE_OPTS="${GRADLE_OPTS} -Djavax.net.ssl.trustStore=/etc/ssl/certs/java/cacerts -Djavax.net.ssl.trustStoreType=jks"

# Also create gradle.properties for better compatibility
GRADLE_USER_HOME="${GRADLE_USER_HOME:-$HOME/.gradle}"
mkdir -p "$GRADLE_USER_HOME"
GRADLE_PROPS="$GRADLE_USER_HOME/gradle.properties"

# Backup existing gradle.properties if it exists and doesn't have our marker
if [ -f "$GRADLE_PROPS" ] && ! grep -q "# AUTO-GENERATED BY CLAUDE CODE SESSION-START HOOK" "$GRADLE_PROPS"; then
  cp "$GRADLE_PROPS" "$GRADLE_PROPS.backup"
  echo "Backed up existing gradle.properties to gradle.properties.backup"
fi

# Write proxy configuration to gradle.properties
cat > "$GRADLE_PROPS" << EOF
# AUTO-GENERATED BY CLAUDE CODE SESSION-START HOOK
# This file is regenerated on each session start

systemProp.http.proxyHost=${PROXY_HOST}
systemProp.http.proxyPort=${PROXY_PORT}
systemProp.https.proxyHost=${PROXY_HOST}
systemProp.https.proxyPort=${PROXY_PORT}
systemProp.http.nonProxyHosts=localhost|127.0.0.1|*.local

# Disable toolchain auto-download since proxy authentication doesn't work
org.gradle.java.installations.auto-download=false

# Manually specify Java installation paths for toolchain detection
org.gradle.java.installations.paths=/usr/lib/jvm/java-21-openjdk-amd64
EOF

# Add authentication if present
if [ -n "$PROXY_USER" ]; then
  cat >> "$GRADLE_PROPS" << EOF
systemProp.http.proxyUser=${PROXY_USER}
systemProp.http.proxyPassword=${PROXY_PASSWORD}
systemProp.https.proxyUser=${PROXY_USER}
systemProp.https.proxyPassword=${PROXY_PASSWORD}
EOF
fi

# Pre-download Gradle distribution using curl (which works with the proxy)
# This avoids the Java proxy authentication issue
GRADLE_VERSION="9.1.0"
GRADLE_DIST_URL="https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip"
GRADLE_USER_HOME="${GRADLE_USER_HOME:-$HOME/.gradle}"
GRADLE_DIST_BASE_DIR="$GRADLE_USER_HOME/wrapper/dists/gradle-${GRADLE_VERSION}-bin"

# Check if Gradle is already fully installed in any hash directory
GRADLE_INSTALLED=false
if [ -d "$GRADLE_DIST_BASE_DIR" ]; then
  for dir in "$GRADLE_DIST_BASE_DIR"/*; do
    if [ -d "$dir/gradle-${GRADLE_VERSION}" ] && [ -f "$dir/gradle-${GRADLE_VERSION}-bin.zip.ok" ]; then
      echo "Gradle $GRADLE_VERSION already installed in $(basename $dir)"
      GRADLE_INSTALLED=true
      break
    fi
  done
fi

if [ "$GRADLE_INSTALLED" = "false" ]; then
  echo "Pre-downloading Gradle $GRADLE_VERSION with curl..."
  mkdir -p "$GRADLE_DIST_BASE_DIR"

  # Find or create a temporary download directory
  TEMP_DOWNLOAD_DIR="$GRADLE_DIST_BASE_DIR/curl-download-temp"
  mkdir -p "$TEMP_DOWNLOAD_DIR"
  GRADLE_ZIP_PATH="$TEMP_DOWNLOAD_DIR/gradle-${GRADLE_VERSION}-bin.zip"

  # Download with curl if not already downloaded
  if [ ! -d "$TEMP_DOWNLOAD_DIR/gradle-${GRADLE_VERSION}" ]; then
    echo "Downloading to $TEMP_DOWNLOAD_DIR..."

    # Download with curl (follows redirects, supports resume, retries)
    if curl -L -f -C - --retry 5 --retry-delay 2 --max-time 300 -o "$GRADLE_ZIP_PATH" "$GRADLE_DIST_URL"; then
      echo "Download successful, extracting..."
      cd "$TEMP_DOWNLOAD_DIR"
      unzip -q "gradle-${GRADLE_VERSION}-bin.zip"
      echo "ok" > "$TEMP_DOWNLOAD_DIR/gradle-${GRADLE_VERSION}-bin.zip.ok"
      echo "Gradle $GRADLE_VERSION downloaded successfully"
    else
      echo "Warning: Failed to download Gradle after retries"
      rm -f "$GRADLE_ZIP_PATH"
    fi
  fi

  # Copy to any existing wrapper-created directories that need it
  if [ -d "$TEMP_DOWNLOAD_DIR/gradle-${GRADLE_VERSION}" ]; then
    for dir in "$GRADLE_DIST_BASE_DIR"/*; do
      if [ -d "$dir" ] && [ "$dir" != "$TEMP_DOWNLOAD_DIR" ] && [ ! -d "$dir/gradle-${GRADLE_VERSION}" ]; then
        echo "Installing Gradle to $(basename $dir)..."
        cp -r "$TEMP_DOWNLOAD_DIR"/* "$dir/"
        echo "Gradle installed to $(basename $dir)"
      fi
    done
  fi
fi

# Set JAVA_HOME if not already set
if [ -z "$JAVA_HOME" ]; then
  # Find Java 21 installation
  if [ -d "/usr/lib/jvm/java-21-openjdk-amd64" ]; then
    export JAVA_HOME="/usr/lib/jvm/java-21-openjdk-amd64"
    echo "JAVA_HOME set to: $JAVA_HOME"
  fi
fi

echo "Proxy configuration complete"
echo "JAVA_HOME: $JAVA_HOME"
echo "JAVA_OPTS: $JAVA_OPTS"
echo "GRADLE_OPTS: $GRADLE_OPTS"
echo "gradle.properties: $GRADLE_PROPS"
