#!/usr/bin/env bash
# Smoke test for the documented user workflow.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
DB_PATH="${1:-/tmp/spector-workflow.db}"

cleanup() {
    (cd "$PROJECT_ROOT" && ./tools/spector-server stop >/dev/null 2>&1) || true
    rm -f "$DB_PATH"
}

trap cleanup EXIT

assert_contains() {
    local haystack="$1"
    local needle="$2"
    if [[ "$haystack" != *"$needle"* ]]; then
        echo "Assertion failed: expected output to contain: $needle" >&2
        exit 1
    fi
}

strip_ansi() {
    sed -r 's/\x1B\[[0-9;]*m//g'
}

assert_json_array_length() {
    local json="$1"
    local path="$2"
    local expected="$3"
    local actual
    actual="$(printf '%s\n' "$json" | jq -r "$path | length")"
    if [[ "$actual" != "$expected" ]]; then
        echo "Assertion failed: expected $path length to be $expected, got $actual" >&2
        exit 1
    fi
}

echo "Indexing project into $DB_PATH"
(cd "$PROJECT_ROOT" && ./tools/spector-index project "$DB_PATH")

echo "Starting server"
(cd "$PROJECT_ROOT" && ./tools/spector-server start "$DB_PATH")

echo "Checking health endpoint"
health_output="$(cd "$PROJECT_ROOT" && ./tools/spector-api health | strip_ansi)"
assert_contains "$health_output" '"status"'
assert_contains "$health_output" '"ok"'

echo "Checking package listing"
packages_output="$(cd "$PROJECT_ROOT" && ./tools/spector-api packages dev.toliner.spector.storage | strip_ansi)"
assert_contains "$packages_output" '"ok": true'
assert_contains "$packages_output" 'dev.toliner.spector.storage.TypeIndexer'

echo "Checking member kind filter"
members_output="$(cd "$PROJECT_ROOT" && ./tools/spector-api members dev.toliner.spector.storage.TypeIndexer --kind METHOD | strip_ansi)"
assert_contains "$members_output" '"ok": true'
assert_contains "$members_output" '"methods"'
if command -v jq >/dev/null 2>&1; then
    assert_json_array_length "$members_output" '.data.members.fields' '0'
else
    assert_contains "$members_output" '"fields": []'
fi

echo "Checking hierarchy endpoint"
hierarchy_output="$(cd "$PROJECT_ROOT" && ./tools/spector-api hierarchy dev.toliner.spector.storage.TypeIndexer | strip_ansi)"
assert_contains "$hierarchy_output" '"ok": true'
assert_contains "$hierarchy_output" '"superclassChain"'

echo "Workflow smoke test passed"
